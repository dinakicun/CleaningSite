@page
@model IndexModel
@{
    ViewData["Title"] = "Клининг в Казани";
}

<section class="hero">
    <div class="hero__overlay"></div>

    <div class="hero__bubbles" id="bubbleField"></div>
    <div class="hero__foam"></div>


    <div class="hero__content">
        <h1 class="hero__title">Откройте для себя простую чистоту в Казани</h1>
        <p class="hero__subtitle">Профессиональная уборка квартир</p>
        <a href="#contact" class="btn-primary">Оставить заявку</a>
    </div>
</section>


<section class="services" id="services">
    <h2 class="services__title">Наши услуги</h2>
    <div class="services__grid">
        <div class="service-card">
            <div class="service-card__icon">🏠</div>
            <h3 class="service-card__title">Быстрая уборка</h3>
            <p class="service-card__text">Поддерживающая уборка - идеальный выбор для регулярного порядка.</p>
        </div>
        <div class="service-card">
            <div class="service-card__icon">🏢</div>
            <h3 class="service-card__title">Генеральная уборка</h3>
            <p class="service-card__text">Глубокая уборка всей квартиры: моем окна, технику внутри, мебель и труднодоступные места. </p>
        </div>
        <div class="service-card">
            <div class="service-card__icon">🔨</div>
            <h3 class="service-card__title">Уборка после ремонта</h3>
            <p class="service-card__text">
                Убираем строительную пыль, следы краски и герметика. Квартира готова к жизни сразу после нашего ухода.
            </p>
        </div>
    </div>
</section>

<section class="stats" id="stats">
    <h2 class="stats__title">С нами безопасно</h2>
    <div class="stats__grid">
        <div class="stat-item">
            <div class="stat-item__number" data-target="9">0</div>
            <div class="stat-item__label">лет опыта в клининге</div>
        </div>
        <div class="stat-item">
            <div class="stat-item__number" data-target="500">0</div>
            <div class="stat-item__label">положительных отзывов</div>
        </div>
        <div class="stat-item">
            <div class="stat-item__heading">Обученный персонал</div>
            <div class="stat-item__label">проверенные и аттестованные клинеры</div>
        </div>
        <div class="stat-item">
            <div class="stat-item__heading">Проф. оборудование</div>
            <div class="stat-item__label">профессиональная химия и инвентарь — привозим всё своё</div>
        </div>
        <div class="stat-item">
            <div class="stat-item__heading">Уборка под контролем</div>
            <div class="stat-item__label">менеджер на связи от заявки до приёмки работы</div>
        </div>
        <div class="stat-item">
            <div class="stat-item__heading">Оплата по факту</div>
            <div class="stat-item__label">платите только после проверки результата</div>
        </div>
    </div>
</section>

<section class="contact" id="contact">
    <h2 class="contact__title">Оставьте заявку</h2>
    <p class="contact__subtitle">Перезвоним в течение 15 минут, ответим на вопросы и рассчитаем стоимость</p>
    <form method="post" class="contact__form">
        <input asp-for="Request.Name" class="contact__input" placeholder="Ваше имя" />
        <input asp-for="Request.Phone" class="contact__input" placeholder="Телефон" />
        <button type="submit" class="btn-primary">Отправить</button>
    </form>
</section>

@section Scripts {
    <script src="~/js/bubbles.js"></script>
    <script src="~/js/counter.js"></script>
}
