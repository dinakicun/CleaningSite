@page
@model IndexModel
@{
    ViewData["Title"] = "Клининг в Казани";
}

<section class="hero">
    <div class="hero__overlay"></div>

    <div class="hero__bubbles" id="bubbleField"></div>
    <div class="hero__foam"></div>


    <div class="hero__content">
        <h1 class="hero__title">Откройте для себя простую чистоту в Казани</h1>
        <p class="hero__subtitle">Профессиональная уборка квартир, офисов и помещений после ремонта</p>
        <a href="#contact" class="btn-primary">Оставить заявку</a>
    </div>
</section>


<section class="services" id="services">
    <h2 class="services__title">Наши услуги</h2>
    <div class="services__grid">
        <div class="service-card">
            <div class="service-card__icon">🏠</div>
            <h3 class="service-card__title">Быстрая уборка</h3>
            <p class="service-card__text">Поддерживающая уборка - идеальный выбор для регулярного порядка.</p>
        </div>
        <div class="service-card">
            <div class="service-card__icon">🏢</div>
            <h3 class="service-card__title">Генеральная уборка</h3>
            <p class="service-card__text">Глубокая уборка всей квартиры: моем окна, технику внутри, мебель и труднодоступные места. </p>
        </div>
        <div class="service-card">
            <div class="service-card__icon">🔨</div>
            <h3 class="service-card__title">Уборка после ремонта</h3>
            <p class="service-card__text">
                Убираем строительную пыль, следы краски и герметика. Квартира готова к жизни сразу после нашего ухода.
            </p>
        </div>
    </div>
</section>


@section Scripts {
    <script src="~/js/bubbles.js"></script>
}